# Database Configuration
DB_USER=raise_user
DB_PASSWORD=your_secure_password_change_me
DB_NAME=raise_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://raise_user:your_secure_password_change_me@db:5432/raise_db

# Redis & Celery Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
# AES-256-GCM key for message encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-string-here-generate-with-openssl-rand-hex-32

# Supabase Configuration (for later implementation)
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key

# Application Settings
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1
